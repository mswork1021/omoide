# TimeTravel Press - Environment Variables

# ===================
# Google AI API (Gemini 2.5 Pro + Imagen 4.0 Ultra)
# ===================
# Google AI Studio で取得: https://aistudio.google.com/
# 注意: Imagen 4.0 Ultra は Gemini API と同じキーを使用
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ===================
# Stripe (決済)
# ===================
# Stripe Dashboard で取得: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===================
# App Configuration
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ===================
# Admin Page Access
# ===================
# true: /admin ページにアクセス可能（管理者テスト用）
# false または未設定: /admin ページにアクセス不可
NEXT_PUBLIC_MAINTENANCE_MODE=true

# ===================
# Admin Authentication
# ===================
# 管理者パスワード（サーバー側のみ、ブラウザには公開されない）
# /admin ページへのログインとテストコードに使用
ADMIN_PASSWORD=your_secure_admin_password_here
